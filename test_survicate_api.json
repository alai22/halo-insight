            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{SURVICATE_API_KEY}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "https://api.survicate.com/v1/surveys",
          "protocol": "https",
          "host": [
            "api",
            "survicate",
            "com"
          ],
          "path": [
            "v1",
            "surveys"
          ]
        },
        "description": "Test listing all surveys. Expected: 403 Forbidden with AWS S3 error"
      },
      "response": []
    },
    {
