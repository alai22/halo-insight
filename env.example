# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Gladly API Configuration
GLADLY_API_KEY=your-gladly-api-key-here
GLADLY_AGENT_EMAIL=your.email@halocollar.com

# Zoom API Configuration (OAuth 2.0 Server-to-Server)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Jira API Configuration (Bug Triage Copilot)
# Base URL of your Jira Cloud site (no trailing slash)
JIRA_BASE_URL=https://halocollar.atlassian.net
# Option A - Basic auth: email + API token (create at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
# Option B - OAuth 2.0: set client ID/secret (from IT) and APP_BASE_URL; then use "Connect to Jira" in Tools
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
# Required for OAuth callback. Must match the callback URL registered in Atlassian (e.g. https://insight.halocollar.com)
# APP_BASE_URL is also used for other redirects (see Application Base URL below)

# Bug Triage backlog overview — scorecard mode (optional, default off)
# When enabled: JSON shortlist + rubric scores → server computes Raise/Lower (more stable, extra Claude calls).
# Full reference: docs/jira-bug-triage-scorecard.md
# Scorecard v2: 14-point additive rubric (see docs/jira-bug-triage-scorecard.md)
# JIRA_TRIAGE_SCORECARD_ENABLED=1
# JIRA_TRIAGE_SCORECARD_MAX_KEYS=40
# JIRA_TRIAGE_SCORECARD_INCLUDE_GA_BLOCKERS=1
# JIRA_TRIAGE_SCORECARD_MIN_DELTA_RANKS=1
# JIRA_TRIAGE_SCORECARD_SCHEMA_VERSION=2
# JIRA_TRIAGE_SCORECARD_SHORTLIST_MAX_TOKENS=1536
# Clamp scorecard reach for Jira issues labeled ai-created (synthetic QA scenarios). Defaults on; set MAX_REACH=3 to disable clamp.
# JIRA_TRIAGE_SCORECARD_AI_CREATED_ENABLED=1
# JIRA_TRIAGE_SCORECARD_AI_CREATED_MAX_REACH=2
# Legacy v1 (ignored when using scorecard v2): MIN_CONFIDENCE, WEIGHTS_JSON, THRESHOLDS_JSON
# JIRA_BACKLOG_OVERVIEW_TEMPERATURE=0

# Claude Model (optional)
# See docs/MODEL_COMPATIBILITY.md for available models
# Default: claude-sonnet-4 (non-dated alias - routes to latest Sonnet 4, recommended for RAG)
# Note: Model aliases are automatically applied - unavailable models fall back to working ones
# Using non-dated aliases (e.g., claude-sonnet-4) is more robust than dated snapshots
CLAUDE_MODEL=claude-sonnet-4

# Claude API Timeout (optional)
# Timeout in seconds for Claude API requests. Default: 120 seconds
# Increase this if you're experiencing timeout errors with complex queries
CLAUDE_API_TIMEOUT=120

# PII Protection Configuration (optional)
# Protect Personally Identifiable Information before sending data to Claude API
# Default: hash (deterministic hash - same input produces same hash for consistency)
# Options:
#   - hash: Replace PII with deterministic hash (e.g., [EMAIL:abc123def456])
#   - redact: Replace PII with [REDACTED_EMAIL] placeholder
#   - remove: Remove PII entirely
#   - none: Disable PII protection (not recommended for production)
PII_REDACT_MODE=hash

# Preserve Customer/Conversation IDs (optional)
# Set to 'true' to keep original IDs instead of pseudonymizing them
# Default: false (IDs will be pseudonymized)
PII_PRESERVE_IDS=false

# Enable Name Detection (optional)
# Set to 'true' to attempt detection and redaction of names in text
# Warning: May have false positives, use with caution
# Default: false
PII_ENABLE_NAME_DETECTION=false

# Storage Configuration
STORAGE_TYPE=s3
CONVERSATION_FILE=conversation_items.jsonl

# S3 Configuration (when STORAGE_TYPE=s3)
S3_BUCKET_NAME=your-gladly-conversations-bucket
S3_FILE_KEY=conversation_items.jsonl
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Azure Blob Storage Configuration (when STORAGE_TYPE=azure)
AZURE_CONNECTION_STRING=your-azure-connection-string
AZURE_CONTAINER_NAME=gladly-conversations
AZURE_BLOB_NAME=conversation_items.jsonl

# Local file configuration (when STORAGE_TYPE=local)
LOCAL_FILE_PATH=conversation_items.jsonl

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true

# Flask Session Secret Key (optional)
# If not set, a random key will be generated on each restart
# For production, set a fixed secret key for session persistence
FLASK_SECRET_KEY=your-secret-key-here

# Authentication Password (optional)
# Password for password-based login. Default: gladly2024
# Temporarily re-enabled as alternative to Google SSO (available until end of Feb 2026)
# IMPORTANT: Keep this secure - never commit to version control
# Set this in your .env file (not in code)
AUTH_PASSWORD=gladly2024

# Admin Password (optional)
# Separate password for admin tools (Claude Chat, Download Manager, etc.)
# Temporarily re-enabled as alternative to Google SSO (available until end of Feb 2026)
# If not set, admin password login will not work (use ADMIN_EMAIL with Google SSO instead)
# IMPORTANT: Keep this secure - never commit to version control
ADMIN_PASSWORD=your-admin-password-here

# Admin Email (optional, for Google SSO)
# Email address(es) that should have admin access when logging in via Google SSO
# Can be a single email or comma-separated list: admin1@halocollar.com,admin2@halocollar.com
# If set, users with these emails will automatically get admin access via Google SSO
ADMIN_EMAIL=alai@halocollar.com

# Allowed email domains for magic link and Google SSO (comma-separated, no @ prefix)
# Default if unset: halocollar.com only. Add partners e.g. halocollar.com,softeq.com
ALLOWED_EMAIL_DOMAINS=halocollar.com,softeq.com

# Application Base URL (optional)
# Used for generating magic link URLs in emails
# If not set, will be inferred from request headers
# Example: https://your-domain.com or http://localhost:5000
APP_BASE_URL=

# Google OAuth Configuration (optional)
# Required for Google SSO authentication
# Get these from IT after they create an OAuth application in Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=your-client-id-from-it.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-from-it
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Port Configuration
PORT=5000
HOST=0.0.0.0

# Email Notification Configuration (optional)
# Enable email notifications when downloads complete
EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
# For Gmail: Use an App Password (NOT your regular password)
# 1. Enable 2-Step Verification in your Google Account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail" and use it here
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com